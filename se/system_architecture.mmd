flowchart LR
    subgraph RuralAqueductActors["👤 ASADA Paso Ancho Employee"]
        direction LR

        F_CONSULT_SD["🟩 Consult water supply<br/>and demand data"]
        F_DEF_DIST["🟩 Define water<br/>distribution rules"]
        F_CONSULT_WL["🟩 Consult<br/>water loss data"]
        F_IMPL_WL_MIT["🟩 Implement water loss<br/>mitigation strategy"]
    end

    subgraph Sensors["📦 ASADA Paso Ancho Sensors"]
        direction LR
        SENSOR_OCTAVE["🟩 Octave Water Meter"]
        SENSOR_LEVEL["🟩 Submersible Water<br/>Level Sensor"]
    end

    subgraph ExtDataAgg["📦 External data aggregators (SA)"]
        direction LR
        SF_ED1["🟩 Receive<br/>aqueduct data"]
    end

    subgraph RuralAqueductSystem["⚙️ System"]
        direction LR

        SF_AQ5["🟩 Notify of<br/>insufficient supply events"]
        SF_AQ6["🟩 Predict water<br/>supply and demand"]
        SF_AQ12["🟩 Notify of high<br/>insufficient supply<br/> probability"]
        SF_AQ10["🟩 Collect water<br/>supply and demand (S/D) measurements <br/><br/>{c} Real-time and remote<br/>"]
        SF_AQ15["🟩 Store<br/>measurements and events<br/><br/>{c} Timestamped"]
        SF_AQ14["🟩 Present<br/>stored data<br/><br/>{c} Time series graphs<br/>{c} Filtered<br/>"]
        SF_AQ13["🟩 Make data accessible<br/>to external entities"]
        SF_AQ8["🟩 Quantify<br/>water loss<br/><br/>{c} Detect discrete water loss<br/>events (tank overflow,<br/>pipe burst)"]
        SF_AQ16["🟩 Predict water<br/>loss event risk"]
        SF_AQ7["🟩 Notify of significant<br/>water loss events"]
        SF_AQ11["🟩 Notify of high<br/>water loss event probability"]
    end

    %% Rural aqueduct human activity exchanges
    SF_AQ14 -->|"📨 Water loss<br/>data"| F_CONSULT_WL
    SF_AQ14 -->|"📨 S/D<br/>data"| F_CONSULT_SD
    SF_AQ7 -->|"📨 Significant water<br/>loss event"| F_IMPL_WL_MIT
    SF_AQ11 -->|"📨 High water loss<br/>event probability"| F_IMPL_WL_MIT
    SF_AQ5 -->|"📨 Insufficient<br/>supply event"| F_DEF_DIST
    SF_AQ12 -->|"📨 High insufficient<br/>supply probability"| F_DEF_DIST
    F_CONSULT_SD -->|"📨 Analysis-based<br/>decision"| F_DEF_DIST
    F_CONSULT_WL -->|"📨 Analysis-based<br/>decision"| F_IMPL_WL_MIT
    F_DEF_DIST -->|"📨 Insufficient supply<br/>alert criteria"| SF_AQ5
    F_DEF_DIST -->|"📨 Insufficient supply<br/>probability alert criteria"| SF_AQ12
    F_IMPL_WL_MIT -->|"📨 Water loss detection<br/>alert criteria"| SF_AQ8
    F_IMPL_WL_MIT -->|"📨 Water loss probability<br/>alert criteria"| SF_AQ11

    %% Sensor exchanges
    SENSOR_OCTAVE -->|"📨 Water Volume,<br/>Current Flow"| SF_AQ10
    SENSOR_LEVEL -->|"📨 Water Level"| SF_AQ10

    %% External data aggregators exchange
    SF_AQ13 -->|"📨 Shareable<br/>data"| SF_ED1

    %% Internal System exchanges
    SF_AQ8 -->|"📨 Water loss<br/>quantification"| SF_AQ7
    SF_AQ16 -->|"📨 Water loss<br/>risk prediction"| SF_AQ11

    SF_AQ15 -->|"📨 Stored<br/>data"| SF_AQ14
    SF_AQ10 -->|"📨 S/D<br/>measurements"| SF_AQ6
    SF_AQ10 -->|"📨 S/D<br/>measurements"| SF_AQ8
    SF_AQ10 -->|"📨 S/D<br/>measurements"| SF_AQ5
    SF_AQ6 -->|"📨 S/D<br/>predictions"| SF_AQ12
    SF_AQ8 -->|"📨 Water loss<br/>quantification"| SF_AQ16

    %% Storage exchanges
    SF_AQ10 -->|"📨 S/D<br/>measurements"| SF_AQ15
    SF_AQ8 -->|"📨 Water loss<br/>quantification"| SF_AQ15
    SF_AQ6 -->|"📨 S/D<br/>predictions"| SF_AQ15
    SF_AQ16 -->|"📨 Risk<br/>predictions"| SF_AQ15
    SF_AQ5 -->|"📨 Insufficient<br/>supply events"| SF_AQ15
    SF_AQ7 -->|"📨 Significant water<br/>loss events"| SF_AQ15
    SF_AQ11 -->|"📨 High water loss<br/>probability events"| SF_AQ15
    SF_AQ12 -->|"📨 High insufficient<br/>supply probability events"| SF_AQ15

    %% External accessibility exchange
    SF_AQ15 -->|"📨 Stored<br/>data"| SF_AQ13

    %% Styling
    classDef actorFunctionClass fill:#f9e79f,stroke:#b7950b,stroke-width:2px
    classDef systemFunctionClass fill:#90ee90,stroke:#228b22,stroke-width:2px
    classDef systemClass fill:#e6f3ff,stroke:#0066cc,stroke-width:3px
    classDef externalClass fill:#e6ffe6,stroke:#009900,stroke-width:3px
    classDef actorContainerClass fill:#fff9e6,stroke:#d4a017,stroke-width:2px,stroke-dasharray: 3 3

    class F_CONSULT_WL,F_CONSULT_SD,F_DEF_DIST,F_IMPL_WL_MIT actorFunctionClass
    class SENSOR_OCTAVE,SENSOR_LEVEL systemFunctionClass
    class Sensors externalClass
    class SF_ED1,SF_AQ5,SF_AQ6,SF_AQ7,SF_AQ8,SF_AQ10,SF_AQ11,SF_AQ12,SF_AQ13,SF_AQ14,SF_AQ15,SF_AQ16 systemFunctionClass
    class RuralAqueductSystem systemClass
    class ExtDataAgg externalClass
    class RuralAqueductActors actorContainerClass
