digraph FC_ProvideWLData {
  graph [
    label="Functional Chain: Provide Water Loss Data";
    labelloc=t;
    rankdir=LR;
    splines=spline;
    nodesep=0.40;
    ranksep=1.05;
    pad=0.35;
    bgcolor="white";
    fontname="Helvetica";
    fontsize=14;
  ];

  node [
    shape=box,
    style="rounded,filled",
    fontname="Helvetica",
    margin="0.15,0.10",
    penwidth=2
  ];

  edge [
    color="#4A4A97",
    penwidth=2,
    fontname="Helvetica",
    fontsize=9
  ];

  // ── Sensors ───────────────────────────────────────────────────────────
  F_MEASURE_VOLUME [
    label=<<B>Measure water<BR/>volume</B><BR/><FONT POINT-SIZE="9"><I>Octave Water Meter</I></FONT>>,
    fillcolor="#f9e79f", color="#b7950b"
  ];
  F_MEASURE_FLOW [
    label=<<B>Measure current<BR/>flow</B><BR/><FONT POINT-SIZE="9"><I>Octave Water Meter</I></FONT>>,
    fillcolor="#f9e79f", color="#b7950b"
  ];
  F_MEASURE_LEVEL [
    label=<<B>Measure water<BR/>level</B><BR/><FONT POINT-SIZE="9"><I>Level Sensor</I></FONT>>,
    fillcolor="#f9e79f", color="#b7950b"
  ];

  // ── System ────────────────────────────────────────────────────────────
  SF_AQ10 [
    label=<<B>Collect S/D<BR/>measurements</B><BR/><FONT POINT-SIZE="9"><I>System</I></FONT>>,
    fillcolor="#90ee90", color="#228b22"
  ];
  SF_AQ8 [
    label=<<B>Quantify<BR/>water loss</B><BR/><FONT POINT-SIZE="9"><I>System</I></FONT>>,
    fillcolor="#90ee90", color="#228b22"
  ];
  SF_AQ15 [
    label=<<B>Store measurements<BR/>and events</B><BR/><FONT POINT-SIZE="9"><I>System</I></FONT>>,
    fillcolor="#90ee90", color="#228b22"
  ];
  SF_AQ14 [
    label=<<B>Present stored<BR/>data</B><BR/><FONT POINT-SIZE="9"><I>System</I></FONT>>,
    fillcolor="#90ee90", color="#228b22"
  ];

  // ── Actor ─────────────────────────────────────────────────────────────
  F_CONSULT_WL [
    label=<<B>Consult water loss<BR/>data</B><BR/><FONT POINT-SIZE="9"><I>Employee</I></FONT>>,
    fillcolor="#f9e79f", color="#b7950b"
  ];

  // ── Chain ─────────────────────────────────────────────────────────────
  F_MEASURE_VOLUME -> SF_AQ10 [label="Water Volume"];
  F_MEASURE_FLOW   -> SF_AQ10 [label="Current Flow"];
  F_MEASURE_LEVEL  -> SF_AQ10 [label="Water Level"];
  SF_AQ10          -> SF_AQ8  [label="S/D
measurements"];
  SF_AQ8           -> SF_AQ15 [label="Water loss
quantification"];
  SF_AQ15          -> SF_AQ14 [label="Stored
data"];
  SF_AQ14          -> F_CONSULT_WL [label="Water loss data"];
}
