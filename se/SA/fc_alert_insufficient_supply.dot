digraph FC_AlertInsufficientSupply {
  graph [
    label="Functional Chain: Alert Insufficient Supply";
    labelloc=t;
    rankdir=LR;
    splines=spline;
    nodesep=0.40;
    ranksep=1.05;
    pad=0.35;
    bgcolor="white";
    fontname="Helvetica";
    fontsize=14;
  ];

  node [
    shape=box,
    style="rounded,filled",
    fontname="Helvetica",
    margin="0.15,0.10",
    penwidth=2
  ];

  edge [
    color="#4A4A97",
    penwidth=2,
    fontname="Helvetica",
    fontsize=9
  ];

  // ── Sensors ───────────────────────────────────────────────────────────
  F_MEASURE_VOLUME [
    label=<<B>Measure water<BR/>volume</B><BR/><FONT POINT-SIZE="9"><I>Octave Water Meter</I></FONT>>,
    fillcolor="#f9e79f", color="#b7950b"
  ];
  F_MEASURE_FLOW [
    label=<<B>Measure current<BR/>flow</B><BR/><FONT POINT-SIZE="9"><I>Octave Water Meter</I></FONT>>,
    fillcolor="#f9e79f", color="#b7950b"
  ];
  F_MEASURE_LEVEL [
    label=<<B>Measure water<BR/>level</B><BR/><FONT POINT-SIZE="9"><I>Level Sensor</I></FONT>>,
    fillcolor="#f9e79f", color="#b7950b"
  ];

  // ── System ────────────────────────────────────────────────────────────
  SF_AQ10 [
    label=<<B>Collect S/D<BR/>measurements</B><BR/><FONT POINT-SIZE="9"><I>System</I></FONT>>,
    fillcolor="#90ee90", color="#228b22"
  ];

  // Path A – real-time threshold
  SF_AQ5 [
    label=<<B>Notify of insufficient<BR/>supply events</B><BR/><FONT POINT-SIZE="9"><I>System — Path A: Real-time</I></FONT>>,
    fillcolor="#90ee90", color="#228b22"
  ];

  // Path B – predictive
  SF_AQ6 [
    label=<<B>Predict water supply<BR/>and demand</B><BR/><FONT POINT-SIZE="9"><I>System — Path B: Predictive</I></FONT>>,
    fillcolor="#90ee90", color="#228b22"
  ];
  SF_AQ12 [
    label=<<B>Notify of high insufficient<BR/>supply probability</B><BR/><FONT POINT-SIZE="9"><I>System — Path B: Predictive</I></FONT>>,
    fillcolor="#90ee90", color="#228b22"
  ];

  // ── Actor ─────────────────────────────────────────────────────────────
  F_DEF_DIST [
    label=<<B>Define water<BR/>distribution rules</B><BR/><FONT POINT-SIZE="9"><I>Employee</I></FONT>>,
    fillcolor="#f9e79f", color="#b7950b"
  ];

  // ── Chain ─────────────────────────────────────────────────────────────
  F_MEASURE_VOLUME -> SF_AQ10 [label="Water Volume"];
  F_MEASURE_FLOW   -> SF_AQ10 [label="Current Flow"];
  F_MEASURE_LEVEL  -> SF_AQ10 [label="Water Level"];

  // Path A
  SF_AQ10 -> SF_AQ5  [label="S/D
measurements"];
  SF_AQ5  -> F_DEF_DIST [label="Insufficient supply event"];

  // Path B
  SF_AQ10 -> SF_AQ6  [label="S/D
measurements"];
  SF_AQ6  -> SF_AQ12 [label="S/D predictions"];
  SF_AQ12 -> F_DEF_DIST [label="High insufficient supply
probability"];
}
