digraph FC_ShareExternalData {
  graph [
    label="Functional Chain: Share Data with External Entities";
    labelloc=t;
    rankdir=LR;
    splines=spline;
    nodesep=0.40;
    ranksep=1.05;
    pad=0.35;
    bgcolor="white";
    fontname="Helvetica";
    fontsize=14;
  ];

  node [
    shape=box,
    style="rounded,filled",
    fontname="Helvetica",
    margin="0.15,0.10",
    penwidth=2
  ];

  edge [
    color="#4A4A97",
    penwidth=2,
    fontname="Helvetica",
    fontsize=9
  ];

  // ── System ────────────────────────────────────────────────────────────
  SF_AQ10 [
    label=<<B>Collect S/D<BR/>measurements</B><BR/><FONT POINT-SIZE="9"><I>System</I></FONT>>,
    fillcolor="#90ee90", color="#228b22"
  ];
  SF_AQ8 [
    label=<<B>Quantify<BR/>water loss</B><BR/><FONT POINT-SIZE="9"><I>System</I></FONT>>,
    fillcolor="#90ee90", color="#228b22"
  ];
  SF_AQ6 [
    label=<<B>Predict water supply<BR/>and demand</B><BR/><FONT POINT-SIZE="9"><I>System</I></FONT>>,
    fillcolor="#90ee90", color="#228b22"
  ];
  SF_AQ16 [
    label=<<B>Predict water loss<BR/>event risk</B><BR/><FONT POINT-SIZE="9"><I>System</I></FONT>>,
    fillcolor="#90ee90", color="#228b22"
  ];
  SF_AQ15 [
    label=<<B>Store measurements<BR/>and events</B><BR/><FONT POINT-SIZE="9"><I>System</I></FONT>>,
    fillcolor="#90ee90", color="#228b22"
  ];
  SF_AQ13 [
    label=<<B>Make data accessible<BR/>to external entities</B><BR/><FONT POINT-SIZE="9"><I>System</I></FONT>>,
    fillcolor="#90ee90", color="#228b22"
  ];

  // ── External ──────────────────────────────────────────────────────────
  SF_ED1 [
    label=<<B>Receive aqueduct data</B><BR/><FONT POINT-SIZE="9"><I>External Data Aggregators</I></FONT>>,
    fillcolor="#90ee90", color="#009900"
  ];

  // ── Chain ─────────────────────────────────────────────────────────────
  SF_AQ10 -> SF_AQ15 [label="S/D
measurements"];
  SF_AQ8  -> SF_AQ15 [label="Water loss
quantification"];
  SF_AQ6  -> SF_AQ15 [label="S/D predictions"];
  SF_AQ16 -> SF_AQ15 [label="Risk predictions"];

  SF_AQ15 -> SF_AQ13 [label="Stored
data"];
  SF_AQ13 -> SF_ED1  [label="Shareable
data"];
}
