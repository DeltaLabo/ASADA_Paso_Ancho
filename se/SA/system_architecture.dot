digraph SystemArchitecture {
  graph [
    rankdir=TB,
    splines=ortho,
    nodesep=0.7,
    ranksep=0.85,
    pad=0.4,
    compound=true,
    bgcolor="white",
    fontname="Helvetica",
    newrank=true
  ];

  node [
    shape=box,
    style="rounded,filled",
    fontname="Helvetica",
    fontsize=11,
    margin="0.12,0.08"
  ];

  edge [
    color="#228b22",
    penwidth=1.5,
    fontname="Helvetica",
    fontsize=8,
    fontcolor="#333333"
  ];

  // ═══════════════════════════════════════════════════════════════════
  // SENSORS  (top)
  // ═══════════════════════════════════════════════════════════════════
  subgraph cluster_octave {
    label="Octave Water Meter";
    style="rounded,filled"; fillcolor="#e6ffe6"; color="#009900";
    penwidth=2; fontname="Helvetica"; fontsize=11;
    F_MEASURE_VOLUME [label="Measure\nwater volume", fillcolor="#f9e79f", color="#b7950b", penwidth=2];
    F_MEASURE_FLOW   [label="Measure\ncurrent flow",  fillcolor="#f9e79f", color="#b7950b", penwidth=2];
  }

  subgraph cluster_level {
    label="Submersible Water\nLevel Sensor";
    style="rounded,filled"; fillcolor="#e6ffe6"; color="#009900";
    penwidth=2; fontname="Helvetica"; fontsize=11;
    F_MEASURE_LEVEL [label="Measure\nwater level", fillcolor="#f9e79f", color="#b7950b", penwidth=2];
  }

  // ═══════════════════════════════════════════════════════════════════
  // SYSTEM
  // ═══════════════════════════════════════════════════════════════════
  subgraph cluster_system {
    label="System";
    style="rounded,filled"; fillcolor="#e6f3ff"; color="#0066cc";
    penwidth=3; fontname="Helvetica"; fontsize=13;

    // ── Tier 1: Collection ──────────────────────────────────────────
    SF_AQ10 [label="Collect S/D measurements\n\n{c} Real-time and remote",
             fillcolor="#90ee90", color="#228b22", penwidth=2];

    // ── Tier 2: Processing (WL left, S/D right) ────────────────────
    SF_AQ8  [label="Quantify water loss\n\n{c} Detect discrete events\n(overflow, pipe burst)",
             fillcolor="#90ee90", color="#228b22", penwidth=2];
    SF_AQ6  [label="Predict water\nsupply and demand",
             fillcolor="#90ee90", color="#228b22", penwidth=2];

    // ── Tier 3: Notifications (WL left, S/D right) ─────────────────
    SF_AQ16 [label="Predict water\nloss event risk",
             fillcolor="#90ee90", color="#228b22", penwidth=2];
    SF_AQ7  [label="Notify of significant\nwater loss events",
             fillcolor="#90ee90", color="#228b22", penwidth=2];
    SF_AQ11 [label="Notify of high water\nloss event probability",
             fillcolor="#90ee90", color="#228b22", penwidth=2];
    SF_AQ5  [label="Notify of insufficient\nsupply events",
             fillcolor="#90ee90", color="#228b22", penwidth=2];
    SF_AQ12 [label="Notify of high insufficient\nsupply probability",
             fillcolor="#90ee90", color="#228b22", penwidth=2];

    // ── Tier 4: Storage / presentation / export ─────────────────────
    SF_AQ15 [label="Store measurements\nand events\n\n{c} Timestamped",
             fillcolor="#90ee90", color="#228b22", penwidth=2];
    SF_AQ14 [label="Present stored data\n\n{c} Time series graphs\n{c} Filtered",
             fillcolor="#90ee90", color="#228b22", penwidth=2];
    SF_AQ13 [label="Make data accessible\nto external entities",
             fillcolor="#90ee90", color="#228b22", penwidth=2];

    // ── Layout: keep WL left, S/D right ─────────────────────────────
    { rank=same; SF_AQ8;  SF_AQ6;  }
    { rank=same; SF_AQ16; SF_AQ7;  SF_AQ11; SF_AQ5;  SF_AQ12; }
    { rank=same; SF_AQ15; SF_AQ14; SF_AQ13; }
  }

  // ═══════════════════════════════════════════════════════════════════
  // ACTORS  (bottom)
  // ═══════════════════════════════════════════════════════════════════
  subgraph cluster_actors {
    label="ASADA Paso Ancho Employee";
    style="rounded,filled"; fillcolor="#fff9e6"; color="#d4a017";
    penwidth=2; fontname="Helvetica"; fontsize=11;

    // WL actors left, S/D actors right
    F_CONSULT_WL  [label="Consult water\nloss data",           fillcolor="#f9e79f", color="#b7950b", penwidth=2];
    F_IMPL_WL_MIT [label="Implement water loss\nmitigation strategy", fillcolor="#f9e79f", color="#b7950b", penwidth=2];
    F_CONSULT_SD  [label="Consult S/D data",                  fillcolor="#f9e79f", color="#b7950b", penwidth=2];
    F_DEF_DIST    [label="Define water\ndistribution rules",   fillcolor="#f9e79f", color="#b7950b", penwidth=2];
  }

  subgraph cluster_ext_agg {
    label="External Data Aggregators (SA)";
    style="rounded,filled"; fillcolor="#e6ffe6"; color="#009900";
    penwidth=2; fontname="Helvetica"; fontsize=11;
    SF_ED1 [label="Receive\naqueduct data", fillcolor="#90ee90", color="#228b22", penwidth=2];
  }

  // ═══════════════════════════════════════════════════════════════════
  // EDGES — Sensor → Collection
  // ═══════════════════════════════════════════════════════════════════
  F_MEASURE_VOLUME -> SF_AQ10 [label="Water Volume"];
  F_MEASURE_FLOW   -> SF_AQ10 [label="Current Flow"];
  F_MEASURE_LEVEL  -> SF_AQ10 [label="Water Level"];

  // ═══════════════════════════════════════════════════════════════════
  // EDGES — Processing: water-loss pipeline (left)
  // ═══════════════════════════════════════════════════════════════════
  SF_AQ10 -> SF_AQ8  [label="S/D meas."];
  SF_AQ8  -> SF_AQ7  [label="WL quantification"];
  SF_AQ8  -> SF_AQ16 [label="WL quantification"];
  SF_AQ16 -> SF_AQ11 [label="Risk prediction"];

  // ═══════════════════════════════════════════════════════════════════
  // EDGES — Processing: supply/demand pipeline (right)
  // ═══════════════════════════════════════════════════════════════════
  SF_AQ10 -> SF_AQ6  [label="S/D meas."];
  SF_AQ10 -> SF_AQ5  [label="S/D meas."];
  SF_AQ6  -> SF_AQ12 [label="S/D predictions"];

  // ═══════════════════════════════════════════════════════════════════
  // EDGES — All functions → Storage  (muted, unlabelled)
  // ═══════════════════════════════════════════════════════════════════
  SF_AQ10 -> SF_AQ15 [color="#aaccaa", penwidth=1, arrowsize=0.6];
  SF_AQ6  -> SF_AQ15 [color="#aaccaa", penwidth=1, arrowsize=0.6];
  SF_AQ8  -> SF_AQ15 [color="#aaccaa", penwidth=1, arrowsize=0.6];
  SF_AQ16 -> SF_AQ15 [color="#aaccaa", penwidth=1, arrowsize=0.6];
  SF_AQ5  -> SF_AQ15 [color="#aaccaa", penwidth=1, arrowsize=0.6];
  SF_AQ7  -> SF_AQ15 [color="#aaccaa", penwidth=1, arrowsize=0.6];
  SF_AQ11 -> SF_AQ15 [color="#aaccaa", penwidth=1, arrowsize=0.6];
  SF_AQ12 -> SF_AQ15 [color="#aaccaa", penwidth=1, arrowsize=0.6];

  // ═══════════════════════════════════════════════════════════════════
  // EDGES — Storage → Presentation / Export
  // ═══════════════════════════════════════════════════════════════════
  SF_AQ15 -> SF_AQ14 [label="Stored data"];
  SF_AQ15 -> SF_AQ13 [label="Stored data"];

  // ═══════════════════════════════════════════════════════════════════
  // EDGES — System → Actors (dashboard outputs)
  // ═══════════════════════════════════════════════════════════════════
  SF_AQ14 -> F_CONSULT_WL  [label="Water loss data"];
  SF_AQ14 -> F_CONSULT_SD  [label="S/D data"];

  // ═══════════════════════════════════════════════════════════════════
  // EDGES — System → Actors (notifications, muted)
  // ═══════════════════════════════════════════════════════════════════
  SF_AQ7  -> F_IMPL_WL_MIT [color="#aaccaa", penwidth=1, arrowsize=0.6, constraint=false];
  SF_AQ11 -> F_IMPL_WL_MIT [color="#aaccaa", penwidth=1, arrowsize=0.6, constraint=false];
  SF_AQ5  -> F_DEF_DIST    [color="#aaccaa", penwidth=1, arrowsize=0.6, constraint=false];
  SF_AQ12 -> F_DEF_DIST    [color="#aaccaa", penwidth=1, arrowsize=0.6, constraint=false];

  // ═══════════════════════════════════════════════════════════════════
  // EDGES — Actors → System (configuration feedback, muted dashed)
  // ═══════════════════════════════════════════════════════════════════
  F_DEF_DIST    -> SF_AQ5  [color="#d4c088", penwidth=1, arrowsize=0.6, style=dashed, constraint=false];
  F_DEF_DIST    -> SF_AQ12 [color="#d4c088", penwidth=1, arrowsize=0.6, style=dashed, constraint=false];
  F_IMPL_WL_MIT -> SF_AQ8  [color="#d4c088", penwidth=1, arrowsize=0.6, style=dashed, constraint=false];
  F_IMPL_WL_MIT -> SF_AQ11 [color="#d4c088", penwidth=1, arrowsize=0.6, style=dashed, constraint=false];

  // ═══════════════════════════════════════════════════════════════════
  // EDGES — Actor internal
  // ═══════════════════════════════════════════════════════════════════
  F_CONSULT_WL  -> F_IMPL_WL_MIT [label="Analysis-based\ndecision"];
  F_CONSULT_SD  -> F_DEF_DIST    [label="Analysis-based\ndecision"];

  // ═══════════════════════════════════════════════════════════════════
  // EDGES — System → External
  // ═══════════════════════════════════════════════════════════════════
  SF_AQ13 -> SF_ED1 [label="Shareable data"];

}
