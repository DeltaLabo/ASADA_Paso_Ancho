                direction TB
                PF_FORE1["🟩 Seasonal trend<br/>analysis"]
                PF_FORE2["🟩 Hourly forecast<br/>calculation"]
                PF_FORE3["🟩 Anomaly detection"]
            end
            subgraph AlertManager["🚨 Alert Manager<br/><br/>{c} Evaluation interval: 5 min"]
                direction TB
                PF_ALERT1["🟩 Evaluate alert thresholds"]
                PF_ALERT2["🟩 Send email notifications"]
                PF_ALERT3["🟩 Send SMS/WhatsApp notifications"]
            end
            APIServer --> ForecastingEngine
            APIServer --> AlertManager
            style BackendContainer fill:#fff9e6,stroke:#d4a017,stroke-width:3px
            style APIServer fill:#87ceeb,stroke:#0066cc,stroke-width:2px
            style ForecastingEngine fill:#87ceeb,stroke:#0066cc,stroke-width:2px
            style AlertManager fill:#87ceeb,stroke:#0066cc,stroke-width:2px
        end
        
        subgraph FrontendContainer["📊 Dashboard Container<br/>Node.js runtime<br/><br/>{c} Port 3000"]
            direction TB
            subgraph DashboardUI["🖥️ Dashboard UI"]
                direction TB
                PF_UI1["🟩 Render real-time gauges"]
                PF_UI2["🟩 Display historical charts"]
                PF_UI3["🟩 Show forecast graphs"]
                PF_UI4["🟩 Display alert panel"]
            end
            subgraph MobileUI["📱 Mobile Responsive<br/><br/>{c} Touch-friendly controls"]
                direction TB
                PF_MOB1["🟩 Render touch-optimized interface"]
                PF_MOB2["🟩 Cache data for offline use"]
            end
            DashboardUI --> MobileUI
            style FrontendContainer fill:#fff9e6,stroke:#d4a017,stroke-width:3px
            style DashboardUI fill:#87ceeb,stroke:#0066cc,stroke-width:2px
            style MobileUI fill:#87ceeb,stroke:#0066cc,stroke-width:2px
        end
        
        subgraph NginxContainer["🌐 Nginx Reverse Proxy<br/>nginx:alpine<br/><br/>{c} Port 80→3000 (HTTP), 443→3000 (HTTPS), 8086 passthrough"]
            direction TB
            PF_NGINX1["🟩 Route HTTP requests to backend"]
            PF_NGINX2["🟩 Terminate SSL/TLS connections"]
            PF_NGINX3["🟩 Proxy InfluxDB API requests"]
            PF_NGINX4["🟩 Serve static files"]
            style NginxContainer fill:#fff9e6,stroke:#d4a017,stroke-width:3px
        end
        
        subgraph BackupSystem["💾 Backup System<br/>Daily cron job"]
            direction TB
            PF_BACK1["🟩 InfluxDB backup<br/>to /backups"]
            PF_BACK2["🟩 Compress to .tar.gz"]
            PF_BACK3["🟩 Upload to S3<br/>(DigitalOcean Spaces)"]
            style BackupSystem fill:#87ceeb,stroke:#0066cc,stroke-width:2px
        end
        
        DockerEngine --> InfluxDBContainer
        DockerEngine --> BackendContainer
        DockerEngine --> FrontendContainer
        DockerEngine --> NginxContainer
        InfluxDBStorage -.->|"📁 Backup"| BackupSystem
        NginxContainer --> FrontendContainer
        NginxContainer --> BackendContainer
        BackendContainer --> InfluxDBEngine
        FrontendContainer --> APIServer
        
        style DigitalOceanDroplet fill:#e6f3ff,stroke:#0066cc,stroke-width:3px
    end

