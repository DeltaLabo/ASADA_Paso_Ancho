            subgraph InfluxDBEngine["⚙️ InfluxDB Engine"]
                direction TB
                PF_INFLUX1["🟩 Expose HTTP API"]
                PF_INFLUX2["🟩 Authenticate requests"]
                PF_INFLUX3["🟩 Write data to bucket"]
                PF_INFLUX4["🟩 Query time-series data"]
            end
            subgraph InfluxDBStorage["💿 Persistent Volume<br/>Docker volume mount<br/><br/>{c} 90-day retention with downsampling"]
                direction TB
                PF_LTS1["🟩 Persist time-series<br/>measurements"]
                PF_LTS2["🟩 Persist forecast<br/>results"]
                PF_LTS3["🟩 Persist alert<br/>history"]
            end
            InfluxDBEngine --> InfluxDBStorage
            style InfluxDBContainer fill:#fff9e6,stroke:#d4a017,stroke-width:3px
            style InfluxDBEngine fill:#87ceeb,stroke:#0066cc,stroke-width:2px
            style InfluxDBStorage fill:#87ceeb,stroke:#0066cc,stroke-width:2px
        end
        
        subgraph BackendContainer["⚙️ Backend API Container<br/>Node.js runtime"]
            direction TB
            direction TB
            subgraph APIServer["🌐 API Server<br/><br/>{c} Port 3000"]
                direction TB
                PF_API1["🟩 Query measurement data"]
                PF_API2["🟩 Serve forecast predictions"]
                PF_API3["🟩 Update alert configurations"]
                PF_API4["🟩 Stream real-time data"]
            end
