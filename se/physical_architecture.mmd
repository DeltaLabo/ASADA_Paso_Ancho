            PF_DOCKER2["🟩 Run API backend container"]
            PF_DOCKER3["🟩 Run dashboard frontend container"]
            style DockerEngine fill:#87ceeb,stroke:#0066cc,stroke-width:2px
        end
        
        subgraph InfluxDBContainer["💾 InfluxDB Container<br/>influxdb:2.7<br/><br/>{c} Port 8086, Token auth, Bucket: water_data, Org: aqueduct"]
