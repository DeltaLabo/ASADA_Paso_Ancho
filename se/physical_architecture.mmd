    %% Physical connections - cables and signals
    OS_HW -->|"🔴 TP Cable"| Enclosure
    PS_HW -->|"🔴 Gauge 10 cable"| Enclosure
    SolarPanel -->|"🔴 Gauge 10 cable"| PowerSystem
    SIM7600 -->|"🔴 Antenna"| LTEAntenna
    
    %% Internal signal flows
    CurrentConv -->|"📡 Voltage signal"| DataAcquisition
    DataAcquisition -->|"📡 Measurements queue"| MeasurementWindow
    MeasurementWindow -->|"📡 Measurement windows"| DataProcessing
    DataAcquisition -->|"📡 Modbus"| OS_HW
    
    %% Data output flows (XIAO → Cloud VPS)
    XIAO -->|"📡 HTTPS POST<br/>InfluxDB API<br/>(via LTE → Nginx)"| NginxContainer
    XIAO -->|"📡 MQTT event topics"| Notifier
    XIAO -->|"📡 Mobile network"| LTEAntenna
    
    %% Power flow
    PowerSystem -.->|"⚡ Power"| XIAO
    PowerSystem -.->|"⚡ Power"| CurrentConv
    PowerSystem -.->|"⚡ Power"| SIM7600
    
    %% VPS external flows (via Nginx)
    NginxContainer -->|"📡 Port 8086"| InfluxDBEngine
    
    %% VPS internal flows
    APIServer -->|"📡 InfluxDB HTTP API"| InfluxDBEngine
    DashboardUI -->|"📡 REST API<br/>/api/*"| APIServer
    NginxContainer -->|"📡 Proxy pass<br/>Port 3000"| DashboardUI

