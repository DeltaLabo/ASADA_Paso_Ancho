flowchart TB
    subgraph DigitalOceanDroplet["☁️ DigitalOcean Droplet<br/>Basic Droplet<br/>1 vCPU / 2GB RAM / 25GB SSD<br/>$4/month<br/>Ubuntu 22.04 LTS"]
        direction TB
        
        subgraph DockerEngine["🐳 Docker Engine<br/>Container runtime<br/><br/>{c} Exposed ports: 80, 443, 8086"]
            direction TB
