vars: {
  d2-config: {
    layout-engine: elk
  }
}

classes: {
  func: {
    shape: rectangle
    style: {
      fill: "#BDFB9B"
      stroke: "#166534"
      stroke-width: 2
      font-size: 36
    }
  }
  lc: {
    style: {
      fill: "#A9C7E6"
      stroke: "#5B65C9"
      stroke-width: 2
      border-radius: 20
      font-size: 40
    }
  }
  pc: {
    style: {
      fill: "#FFF8BF"
      stroke: "#D1B24A"
      stroke-width: 2
      font-size: 40
    }
  }
  sys: {
    style: {
      fill: "#E6E6E6"
      stroke: "#9A9A9A"
      stroke-width: 2
      font-size: 48
    }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"
      stroke: "#5B65C9"
      stroke-width: 2
      border-radius: 20
      font-size: 40
    }
  }
  note: {
    style: {
      fill: "#FFF5B0"
      stroke: "#D1B24A"
      font-size: 32
    }
  }
  chain: {
    style: {
      fill: "#FFFFFF"
      stroke: "#D1B24A"
      stroke-width: 2
      border-radius: 20
      font-size: 36
    }
  }
  fe: {
    style: {
      stroke: "#1F7A4D"
      font-color: "#1F7A4D"
      stroke-width: 2
      font-size: 30
    }
  }
  ce: {
    style: {
      stroke: "#5B65C9"
      font-color: "#5B65C9"
      stroke-width: 2
      font-size: 30
    }
  }
  pl: {
    style: {
      stroke: "#E11D28"
      font-color: "#E11D28"
      stroke-width: 2
      font-size: 30
    }
  }
  cstr: {
    style: {
      stroke: "#333333"
      stroke-dash: 3
      font-size: 26
    }
  }
}


direction: right

platform: "[System] Aqueduct monitoring platform" {
  class: sys
  direction: right
  grid-columns: 2

  field_node: "[PC] Field Node" {
    class: pc
    direction: down
    grid-columns: 1

    xiao_module: "[PC] Seeed XIAO ESP32-C3" {
      class: pc
      direction: down
      grid-columns: 1

      data_acquisition: "[LC] Data Acquisition" {
        class: lc
        direction: down
        grid-columns: 1

        collect_measurements: "[F] Collect and window\nwater S/D measurements" {
          class: func
          shape: rectangle
        }
        monitor_sensor_health: "[F] Monitor\nsensor health" {
          class: func
          shape: rectangle
        }
      }
    }
  }

  server_host: "[PC] DigitalOcean Premium AMD Droplet\n(4 vCPU / 8 GiB RAM / 160 GiB SSD)" {
    class: pc
    direction: right
    grid-columns: 3

    analytics_container: "[LC] Python Analytics Worker Container" {
      class: lc
      direction: down
      grid-columns: 1

      event_detection: "[LC] Event Detection" {
        class: lc
        direction: down
        grid-columns: 1

        manage_detection_thresholds: "[F] Manage detection\nthresholds" {
          class: func
          shape: rectangle
        }
      }
    }

    config_container: "[LC] FastAPI Application Container" {
      class: lc
      direction: down
      grid-columns: 1

      configuration_api: "[LC] Configuration API" {
        class: lc
        direction: down
        grid-columns: 1

        provide_validation_rules: "[F] Provide current\nvalidation rules" {
          class: func
          shape: rectangle
        }
      }
    }

    traefik_container: "[LC] Traefik Reverse Proxy Container" {
      class: lc
      direction: down
      grid-columns: 1

      gateway: "[LC] Reverse Proxy /\nTLS Gateway" {
        class: lc
        direction: down
        grid-columns: 1

        route_ingest_request: "[F] Terminate TLS and\nroute ingest request" {
          class: func
          shape: rectangle
        }
      }
    }

    ingest_container: "[LC] FastAPI Application Container" {
      class: lc
      direction: down
      grid-columns: 1

      node_ingestion: "[LC] Node Ingestion" {
        class: lc
        direction: down
        grid-columns: 1

        validate_uploaded_telemetry: "[F] Validate node upload\nand accepted ranges" {
          class: func
          shape: rectangle
        }
      }
    }

    influxdb_container: "[LC] InfluxDB OSS 2.7 Container" {
      class: lc
      direction: down
      grid-columns: 1

      long_term_storage: "[LC] Long-term Storage" {
        class: lc
        direction: down
        grid-columns: 1

        store_measurements: "[F] Store\nmeasurements" {
          class: func
          shape: rectangle
        }
      }
    }
  }

  validation_note: "[C] Accepted sensor ranges, timestamp freshness,\nnode identity, and missing-value policy" {
    class: note
    shape: page
  }
  transport_note: "[C] Device authentication via client certificate\nor per-device API token over TLS" {
    class: note
    shape: page
  }
}

platform.field_node.xiao_module.data_acquisition.collect_measurements -> platform.field_node.xiao_module.data_acquisition.monitor_sensor_health: "[FE] Windowed\nreadings" {
  class: fe
}
platform.server_host.analytics_container.event_detection.manage_detection_thresholds -> platform.server_host.config_container.configuration_api.provide_validation_rules: "[FE] Active\nvalidation policy" {
  class: fe
}
platform.server_host.config_container.configuration_api.provide_validation_rules -> platform.server_host.ingest_container.node_ingestion.validate_uploaded_telemetry: "[FE] Validation\nrules" {
  class: fe
}
platform.field_node.xiao_module.data_acquisition.monitor_sensor_health -> platform.server_host.traefik_container.gateway.route_ingest_request: "[FE] HTTPS\nupload" {
  class: fe
}
platform.server_host.traefik_container.gateway.route_ingest_request -> platform.server_host.ingest_container.node_ingestion.validate_uploaded_telemetry: "[FE] Routed\ningest request" {
  class: fe
}
platform.server_host.ingest_container.node_ingestion.validate_uploaded_telemetry -> platform.server_host.influxdb_container.long_term_storage.store_measurements: "[FE] Validated batch\n+ health status" {
  class: fe
}

platform.validation_note -> platform.server_host.ingest_container.node_ingestion.validate_uploaded_telemetry {
  class: cstr
}
platform.transport_note -> platform.server_host.traefik_container.gateway.route_ingest_request {
  class: cstr
}
