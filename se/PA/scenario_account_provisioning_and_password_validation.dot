digraph ScenarioAccountProvisioningAndPasswordValidation {
  graph [
    rankdir=LR,
    splines=ortho,
    newrank=true,
    nodesep=0.55,
    ranksep=1.0,
    pad=0.25,
    compound=true,
    forcelabels=true,
    bgcolor="white",
    fontname="Helvetica"
  ];

  node [
    shape=box,
    style="rounded,filled",
    fillcolor="#FFFCB7",
    color="#7B694F",
    penwidth=2,
    fontname="Helvetica",
    margin="0.12,0.08"
  ];

  edge [
    color="#228B22",
    penwidth=2,
    fontname="Helvetica",
    fontsize=10
  ];

  subgraph cluster_admin_device {
    label="Administrator Client Device";
    color="#7B694F";
    penwidth=2;
    style="rounded,filled";
    fillcolor="#FFF9D6";

    F_ADMIN_AUTH [label="Authenticate as\nadministrator", fillcolor="#F9E79F", color="#B7950B"];
    F_ADMIN_PROVISION [label="Provision and manage\nuser accounts", fillcolor="#F9E79F", color="#B7950B"];

    F_ADMIN_AUTH -> F_ADMIN_PROVISION [style=invis, weight=20];
  }

  subgraph cluster_employee_device {
    label="Employee Client Device";
    color="#7B694F";
    penwidth=2;
    style="rounded,filled";
    fillcolor="#FFF9D6";

    F_USER_LOGIN [label="Authenticate to access\nthe dashboard", fillcolor="#F9E79F", color="#B7950B"];
  }

  subgraph cluster_server_host {
    label="DigitalOcean Premium AMD Droplet\n(4 vCPU / 8 GiB RAM / 160 GiB SSD)";
    color="#7B694F";
    penwidth=2;
    style="rounded,filled";
    fillcolor="#FFF9D6";

    subgraph cluster_access_entry {
      label="Access Entry";
      color="#D0D0D0";
      penwidth=1.5;
      style="rounded,filled";
      fillcolor="white";

      subgraph cluster_traefik {
        label="Traefik Reverse Proxy Container";
        color="#4A4A97";
        penwidth=2;
        style="rounded,filled";
        fillcolor="#DCE8F7";

        lc_gateway [label="Reverse Proxy /\nTLS Gateway", fillcolor="#87CEEB", color="#0066CC"];
      }

      subgraph cluster_grafana {
        label="Grafana Dashboard Container";
        color="#4A4A97";
        penwidth=2;
        style="rounded,filled";
        fillcolor="#DCE8F7";

        subgraph cluster_dashboard_lc {
          label="Dashboard (LC)";
          color="#0066CC";
          penwidth=2;
          style="rounded,filled";
          fillcolor="#87CEEB";

          LF_D_AUTH [label="Authenticate\nuser", fillcolor="#90EE90", color="#228B22"];
        }
      }

      { rank=same; lc_gateway; LF_D_AUTH; }
      lc_gateway -> LF_D_AUTH [style=invis, weight=15];
    }

    subgraph cluster_identity_admin {
      label="Identity Administration & Validation";
      color="#D0D0D0";
      penwidth=1.5;
      style="rounded,filled";
      fillcolor="white";

      subgraph cluster_keycloak {
        label="Keycloak Identity Container";
        color="#4A4A97";
        penwidth=2;
        style="rounded,filled";
        fillcolor="#DCE8F7";

        lc_kc_policy [label="Credential Policy\nRBAC + MFA + lockout", fillcolor="#87CEEB", color="#0066CC"];
        lc_kc_admin [label="Account\nProvisioning", fillcolor="#87CEEB", color="#0066CC"];
        lc_kc_auth [label="Credential Validation\nand OIDC Token Issuance", fillcolor="#87CEEB", color="#0066CC"];
        lc_kc_store [label="Salted Password Hashing\nand Credential Storage", fillcolor="#87CEEB", color="#0066CC"];

        { rank=same; lc_kc_policy; lc_kc_admin; }
        { rank=same; lc_kc_auth; lc_kc_store; }
        lc_kc_policy -> lc_kc_admin [style=invis, weight=15];
        lc_kc_auth -> lc_kc_store [style=invis, weight=15];
        lc_kc_policy -> lc_kc_auth [style=invis, weight=10];
        lc_kc_admin -> lc_kc_store [style=invis, weight=10];
      }
    }

    subgraph cluster_credential_store {
      label="Credential Store";
      color="#D0D0D0";
      penwidth=1.5;
      style="rounded,filled";
      fillcolor="white";

      subgraph cluster_postgres {
        label="PostgreSQL 16 Container";
        color="#4A4A97";
        penwidth=2;
        style="rounded,filled";
        fillcolor="#DCE8F7";

        lc_rel_config [label="Identity Store", fillcolor="#87CEEB", color="#0066CC"];
      }
    }

    storage_c [label="{c}\nPasswords are not stored in Grafana or FastAPI.\nKeycloak stores only salted password hashes in PostgreSQL", fillcolor="#F9E79F", color="#B7950B"];
    admin_c [label="{c}\nAdministrator access requires RBAC and MFA\nwith strong password policy", fillcolor="#F9E79F", color="#B7950B"];
    builtin_c [label="{c}\nKeycloak logical components shown here are\nproduct-provided capabilities", fillcolor="#F9E79F", color="#B7950B"];
    transport_c [label="{c}\nTLS is terminated at Traefik before routing\nto Grafana or Keycloak", fillcolor="#F9E79F", color="#B7950B"];

    storage_c -> admin_c [style=invis, weight=12];
    builtin_c -> transport_c [style=invis, weight=12];
    { rank=same; storage_c; builtin_c; }
    { rank=same; admin_c; transport_c; }
  }

  F_ADMIN_AUTH:e -> lc_gateway:w [xlabel="1.\nHTTPS\nadmin login\nrequest"];
  lc_gateway:e -> lc_kc_auth:w [xlabel="2.\nRouted admin\nauthentication"];
  lc_kc_policy:s -> lc_kc_auth:n [xlabel="3.\nApply MFA\n+ lockout\nrules"];

  F_ADMIN_PROVISION:e -> lc_gateway:w [xlabel="4.\nHTTPS\naccount\nmanagement"];
  lc_gateway:e -> lc_kc_admin:w [xlabel="5.\nRouted account\nadministration"];
  lc_kc_policy:e -> lc_kc_admin:w [xlabel="6.\nApply password\npolicy + RBAC"];
  lc_kc_admin:e -> lc_kc_store:w [xlabel="7.\nCreate / update\ncredential"];
  lc_kc_store:e -> lc_rel_config:w [xlabel="8.\nStore account data\n+ salted hash"];

  F_USER_LOGIN:e -> lc_gateway:w [xlabel="9.\nHTTPS employee\nlogin request"];
  lc_gateway:e -> LF_D_AUTH:w [xlabel="10.\nRouted\ndashboard\nrequest"];
  LF_D_AUTH:e -> lc_kc_auth:w [xlabel="11.\nOIDC auth\nrequest"];
  lc_kc_auth:e -> lc_rel_config:w [xlabel="12.\nRetrieve stored\ncredential hash"];
  lc_kc_auth:w -> LF_D_AUTH:e [xlabel="13.\nIdentity\ntoken /\nclaims", constraint=false, minlen=2];

  storage_c -> lc_kc_store [style=dotted, arrowhead=none, color="#B7950B", constraint=false];
  admin_c -> lc_kc_policy [style=dotted, arrowhead=none, color="#B7950B", constraint=false];
  builtin_c -> lc_kc_auth [style=dotted, arrowhead=none, color="#B7950B", constraint=false];
  transport_c -> lc_gateway [style=dotted, arrowhead=none, color="#B7950B", constraint=false];
}
