digraph ScenarioBackupTimeSeriesDB {
  graph [
    rankdir=LR,
    splines=ortho,
    newrank=true,
    nodesep=0.55,
    ranksep=0.95,
    pad=0.25,
    compound=true,
    forcelabels=true,
    bgcolor="white",
    fontname="Helvetica"
  ];

  node [
    shape=box,
    style="rounded,filled",
    fillcolor="#FFFCB7",
    color="#7B694F",
    penwidth=2,
    fontname="Helvetica",
    margin="0.12,0.08"
  ];

  edge [
    color="#228B22",
    penwidth=2,
    fontname="Helvetica",
    fontsize=10
  ];

  do_spaces [label="DigitalOcean Spaces\nBackup Bucket"];

  subgraph cluster_server_host {
    label="DigitalOcean Premium AMD Droplet\n(4 vCPU / 8 GiB RAM / 160 GiB SSD)";
    color="#7B694F";
    penwidth=2;
    style="rounded,filled";
    fillcolor="#FFF9D6";

    subgraph cluster_operational_data {
      label="Operational Data";
      color="#D0D0D0";
      penwidth=1.5;
      style="rounded,filled";
      fillcolor="white";

      subgraph cluster_influxdb {
        label="InfluxDB OSS 2.7 Container";
        color="#4A4A97";
        penwidth=2;
        style="rounded,filled";
        fillcolor="#DCE8F7";

        subgraph cluster_lts_lc {
          label="Long-term Storage (LC)";
          color="#0066CC";
          penwidth=2;
          style="rounded,filled";
          fillcolor="#87CEEB";

          LF_LTS4 [label="Store\nmeasurements", fillcolor="#90EE90", color="#228B22"];
          LF_LTS6 [label="Store event\ndata", fillcolor="#90EE90", color="#228B22"];
          LF_LTS3 [label="Store forecasts\nand estimates", fillcolor="#90EE90", color="#228B22"];
          LF_LTS5 [label="Query stored\ndata", fillcolor="#90EE90", color="#228B22"];
        }
      }
    }

    subgraph cluster_backup_execution {
      label="Backup Execution";
      color="#D0D0D0";
      penwidth=1.5;
      style="rounded,filled";
      fillcolor="white";

      subgraph cluster_restic {
        label="Restic Backup Container";
        color="#4A4A97";
        penwidth=2;
        style="rounded,filled";
        fillcolor="#DCE8F7";

        lc_backup [label="Encrypted\nBackup Job", fillcolor="#87CEEB", color="#0066CC"];
      }
    }

    schedule_c [label="{c}\nScheduled full + incremental backups\nwith restore verification and encryption", fillcolor="#F9E79F", color="#B7950B"];
    builtin_c [label="{c}\nRestic backup functionality shown here is\nproduct-provided, not custom-developed logic", fillcolor="#F9E79F", color="#B7950B"];

    schedule_c -> builtin_c [style=invis, weight=10];
  }

  LF_LTS4:e -> LF_LTS5:w [xlabel="Measurement\ndataset\nselected"];
  LF_LTS6:e -> LF_LTS5:w [xlabel="Event\ndataset\nselected"];
  LF_LTS3:e -> LF_LTS5:w [xlabel="Forecast\ndataset\nselected"];
  LF_LTS5:e -> lc_backup:w [xlabel="Consistent export\n/ snapshot"];
  lc_backup:e -> do_spaces:w [xlabel="Encrypted backup\nartifact"];

  schedule_c -> lc_backup [style=dotted, arrowhead=none, color="#B7950B", constraint=false];
  builtin_c -> lc_backup [style=dotted, arrowhead=none, color="#B7950B", constraint=false];
}
