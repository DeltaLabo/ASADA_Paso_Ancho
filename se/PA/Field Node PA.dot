digraph FieldNodePA {
  graph [
    rankdir=LR,
    splines=ortho,
    newrank=true,
    nodesep=0.55,
    ranksep=0.9,
    pad=0.3,
    compound=true,
    bgcolor="white",
    fontname="Helvetica"
  ];

  node [
    shape=box,
    style="rounded,filled",
    fillcolor="#FFFCB7",
    color="#7B694F",
    penwidth=2,
    fontname="Helvetica",
    margin="0.12,0.08"
  ];

  edge [
    color="#EF2929",
    penwidth=2,
    fontname="Helvetica",
    fontsize=10
  ];

  subgraph cluster_field_node {
    label="Field Node";
    color="#7B694F";
    penwidth=2;
    style="rounded,filled";
    fillcolor="#FFF9D6";

    subgraph cluster_panel {
      label="Panel";
      color="#7B694F";
      penwidth=2;
      style="rounded";
      solar_panel [label="Waveshare Solar Panel\n(18V 10W)"];
    }

    subgraph cluster_octave {
      label="Flow Meter";
      color="#7B694F";
      penwidth=2;
      style="rounded";
      octave [label="Octave Water Meter"];
    }

    subgraph cluster_level {
      label="Level Sensor";
      color="#7B694F";
      penwidth=2;
      style="rounded";
      level_sensor [label="Submersible Water\nLevel Sensor"];
    }

    subgraph cluster_antenna {
      label="Antenna";
      color="#7B694F";
      penwidth=2;
      style="rounded";
      cellular_antenna [label="Waveshare 4G/3G/2G/LPWA\nOutdoor Antenna"];
    }

    subgraph cluster_enclosure {
      label="IP67 Enclosure";
      color="#7B694F";
      penwidth=2;
      style="rounded,filled";
      fillcolor="#FFFCB7";

      subgraph cluster_controller_pcb {
        label="Controller PCB";
        color="#7B694F";
        penwidth=2;
        style="rounded,filled";
        fillcolor="#FFFCB7";

        subgraph cluster_power {
          label="Power Subsystem";
          color="#7B694F";
          penwidth=2;
          style="rounded";

          solar_manager  [label="Waveshare Solar Power Manager (D)\nMPPT Charger + 5 V Output"];
          battery_holder [label="18650 Battery Holder\n+ 3P1S Li-ion Pack"];
          ina219         [label="INA219 Battery Monitor"];
          power_entry    [label="Molex MicroFit 43045\n4-pin Power Header"];
        }

        subgraph cluster_compute {
          label="Compute";
          color="#7B694F";
          penwidth=2;
          style="rounded,filled";
          fillcolor="#FFFCB7";

          subgraph cluster_expansion {
            label="Seeed Studio Expansion Board Base for XIAO\n(includes RTC + MicroSD slot)";
            color="#7B694F";
            penwidth=2;
            style="rounded,filled";
            fillcolor="#FFFCB7";

            subgraph cluster_xiao {
              label="Seeed XIAO ESP32-C3";
              color="#7B694F";
              penwidth=2;
              style="rounded,filled";
              fillcolor="#FFFCB7";

              lc_da [label="Data Acquisition", fillcolor="#87CEEB", color="#0066CC"];
            }

            xiao [label="GPIO / I²C / UART\nPin Header", fontsize=10];
          }
        }

        subgraph cluster_sensor_if {
          label="Sensor Interfaces";
          color="#7B694F";
          penwidth=2;
          style="rounded";

          rs485         [label="Seeed Grove\nRS485"];
          level_divider [label="Analog\nDivider"];
        }

        subgraph cluster_wan_if {
          label="WAN Interface";
          color="#7B694F";
          penwidth=2;
          style="rounded";

          lte [label="Waveshare SIM7600G-H\n4G Module"];
        }
      }
    }
  }

  // Shape internal ordering
  battery_holder -> ina219      [style=invis];
  ina219         -> solar_manager [style=invis];
  solar_manager  -> power_entry [style=invis];
  rs485          -> level_divider [style=invis];

  // ── Power chain ───────────────────────────────────────────────────
  solar_panel    -> solar_manager [xlabel="DC power cable"];
  battery_holder -> solar_manager [xlabel="2-wire JST"];
  battery_holder -> ina219        [xlabel="BAT+ / BAT−"];
  solar_manager  -> power_entry   [xlabel="5 V + GND"];
  power_entry    -> xiao          [xlabel="5 V + GND"];
  power_entry    -> lte           [xlabel="5 V + GND"];

  // ── Controller wiring ─────────────────────────────────────────────
  xiao -> ina219        [xlabel="SDA/SCL + 3.3 V + GND"];
  xiao -> rs485         [xlabel="TX/RX + 5 V + GND"];
  xiao -> level_divider [xlabel="A0 + GND"];
  xiao -> lte           [xlabel="TX/RX + PWK + GND"];

  // ── External hardware links ───────────────────────────────────────
  octave           -> rs485         [xlabel="RS485 A/B + GND"];
  level_sensor     -> level_divider [xlabel="VOUT + 5 V + GND"];
  cellular_antenna -> lte           [xlabel="RF coax"];

  // Data Acquisition is shown as an allocated logical component inside
  // the physical component, with no LC↔PC link drawn in this diagram.
}
