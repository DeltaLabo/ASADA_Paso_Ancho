vars: {
  d2-config: {
    layout-engine: elk
  }
}

classes: {
  func: {
    shape: rectangle
    style: {
      fill: "#BDFB9B"
      stroke: "#166534"
      stroke-width: 2
      font-size: 36
    }
  }
  lc: {
    style: {
      fill: "#A9C7E6"
      stroke: "#5B65C9"
      stroke-width: 2
      border-radius: 20
      font-size: 40
    }
  }
  pc: {
    style: {
      fill: "#FFF8BF"
      stroke: "#D1B24A"
      stroke-width: 2
      font-size: 40
    }
  }
  sys: {
    style: {
      fill: "#E6E6E6"
      stroke: "#9A9A9A"
      stroke-width: 2
      font-size: 48
    }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"
      stroke: "#5B65C9"
      stroke-width: 2
      border-radius: 20
      font-size: 40
    }
  }
  note: {
    style: {
      fill: "#FFF5B0"
      stroke: "#D1B24A"
      font-size: 32
    }
  }
  chain: {
    style: {
      fill: "#FFFFFF"
      stroke: "#D1B24A"
      stroke-width: 2
      border-radius: 20
      font-size: 36
    }
  }
  fe: {
    style: {
      stroke: "#1F7A4D"
      font-color: "#1F7A4D"
      stroke-width: 2
      font-size: 30
    }
  }
  ce: {
    style: {
      stroke: "#5B65C9"
      font-color: "#5B65C9"
      stroke-width: 2
      font-size: 30
    }
  }
  pl: {
    style: {
      stroke: "#E11D28"
      font-color: "#E11D28"
      stroke-width: 2
      font-size: 30
    }
  }
  cstr: {
    style: {
      stroke: "#333333"
      stroke-dash: 3
      font-size: 26
    }
  }
}


direction: right

platform: "[System] Aqueduct monitoring platform" {
  class: sys
  direction: down
  grid-columns: 1

  server_host: "[PC] DigitalOcean Premium AMD Droplet\n(4 vCPU / 8 GiB RAM / 160 GiB SSD)" {
    class: pc
    direction: right
    grid-columns: 4

    postgres_container: "[LC] PostgreSQL 16 Container" {
      class: lc
      direction: down
      grid-columns: 1

      relational_store: "[LC] Relational Configuration\nand Identity Store" {
        class: lc
        direction: down
        grid-columns: 1

        provide_criteria: "[F] Provide point and\ntrend criteria" {
          class: func
          shape: rectangle
        }
        provide_subscriber_registry: "[F] Provide subscriber\nregistry" {
          class: func
          shape: rectangle
        }
      }
    }

    analytics_container: "[LC] Python Analytics Worker Container" {
      class: lc
      direction: right
      grid-columns: 2

      event_detection: "[LC] Event Detection" {
        class: lc
        direction: down
        grid-columns: 1

        manage_thresholds: "[F] Manage point /\ntrend thresholds" {
          class: func
          shape: rectangle
        }
        identify_water_loss: "[F] Identify significant\nwater loss events" {
          class: func
          shape: rectangle
        }
        identify_insufficient_supply: "[F] Identify insufficient\nsupply events" {
          class: func
          shape: rectangle
        }
      }

      data_processing: "[LC] Data Processing" {
        class: lc
        direction: down
        grid-columns: 1

        predict_supply_demand: "[F] Predict water\nsupply and demand" {
          class: func
          shape: rectangle
        }
        predict_water_loss_risk: "[F] Predict water\nloss event risk" {
          class: func
          shape: rectangle
        }
      }
    }

    notifier_container: "[LC] Python Notification Worker Container" {
      class: lc
      direction: down
      grid-columns: 1

      notifier_lc: "[LC] Notifier" {
        class: lc
        direction: down
        grid-columns: 1

        manage_notification_subscribers: "[F] Manage notification\nsubscribers and channels" {
          class: func
          shape: rectangle
        }
        notify_detected_events: "[F] Notify of\ndetected events" {
          class: func
          shape: rectangle
        }
        notify_predicted_risks: "[F] Notify of predicted\nrisk events" {
          class: func
          shape: rectangle
        }
      }
    }

    influxdb_container: "[LC] InfluxDB OSS 2.7 Container" {
      class: lc
      direction: down
      grid-columns: 1

      long_term_storage: "[LC] Long-term Storage" {
        class: lc
        direction: down
        grid-columns: 1

        store_event_data: "[F] Store event\ndata" {
          class: func
          shape: rectangle
        }
      }
    }
  }

  threshold_note: "[C] Configurable event / risk criteria can trigger from\nan individual data point threshold\nor a trend threshold over a time window\n(e.g. water level rise rate > X for 1 min)" {
    class: note
    shape: page
  }
}

employee_device: "[EA] Employee Client Device" {
  class: ea
  shape: rectangle
  direction: down
  grid-columns: 1

  receive_detected_event: "[F] Receive detected-event\nnotification" {
    class: func
    shape: rectangle
  }
  receive_high_risk: "[F] Receive high-risk\nnotification" {
    class: func
    shape: rectangle
  }
}

platform -> employee_device: {
  style: { opacity: 0 }
}

platform.server_host.postgres_container.relational_store.provide_criteria -> platform.server_host.analytics_container.event_detection.manage_thresholds: "[FE] Point + trend\ncriteria" {
  class: fe
}
platform.server_host.postgres_container.relational_store.provide_subscriber_registry -> platform.server_host.notifier_container.notifier_lc.manage_notification_subscribers: "[FE] Subscriber\nregistry" {
  class: fe
}
platform.server_host.analytics_container.event_detection.manage_thresholds -> platform.server_host.analytics_container.event_detection.identify_water_loss: "[FE] Water loss\ncriteria" {
  class: fe
}
platform.server_host.analytics_container.event_detection.manage_thresholds -> platform.server_host.analytics_container.event_detection.identify_insufficient_supply: "[FE] Supply\ncriteria" {
  class: fe
}
platform.server_host.analytics_container.event_detection.manage_thresholds -> platform.server_host.analytics_container.data_processing.predict_water_loss_risk: "[FE] Point / trend\nrisk criteria" {
  class: fe
}
platform.server_host.analytics_container.data_processing.predict_supply_demand -> platform.server_host.analytics_container.data_processing.predict_water_loss_risk: "[FE] S/D\nforecast" {
  class: fe
}
platform.server_host.analytics_container.event_detection.identify_water_loss -> platform.server_host.notifier_container.notifier_lc.notify_detected_events: "[FE] Detected water\nloss event" {
  class: fe
}
platform.server_host.analytics_container.event_detection.identify_insufficient_supply -> platform.server_host.notifier_container.notifier_lc.notify_detected_events: "[FE] Detected insufficient\nsupply event" {
  class: fe
}
platform.server_host.analytics_container.data_processing.predict_water_loss_risk -> platform.server_host.notifier_container.notifier_lc.notify_predicted_risks: "[FE] Threshold-based\nhigh-risk prediction" {
  class: fe
}
platform.server_host.notifier_container.notifier_lc.manage_notification_subscribers -> platform.server_host.notifier_container.notifier_lc.notify_detected_events: "[FE] Subscriber\nregistry" {
  class: fe
}
platform.server_host.notifier_container.notifier_lc.manage_notification_subscribers -> platform.server_host.notifier_container.notifier_lc.notify_predicted_risks: "[FE] Subscriber\nregistry" {
  class: fe
}
platform.server_host.notifier_container.notifier_lc.notify_detected_events -> employee_device.receive_detected_event: "[FE] Event\nnotification" {
  class: fe
}
platform.server_host.notifier_container.notifier_lc.notify_predicted_risks -> employee_device.receive_high_risk: "[FE] High-risk\nnotification" {
  class: fe
}
platform.server_host.notifier_container.notifier_lc.notify_detected_events -> platform.server_host.influxdb_container.long_term_storage.store_event_data: "[FE] Notification\nrecord" {
  class: fe
}
platform.server_host.notifier_container.notifier_lc.notify_predicted_risks -> platform.server_host.influxdb_container.long_term_storage.store_event_data: "[FE] Prediction notification\nrecord" {
  class: fe
}

platform.threshold_note -> platform.server_host.analytics_container.event_detection.manage_thresholds {
  class: cstr
}
