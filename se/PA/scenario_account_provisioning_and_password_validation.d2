vars: {
  d2-config: {
    layout-engine: elk
  }
}

classes: {
  func: {
    shape: rectangle
    style: {
      fill: "#BDFB9B"
      stroke: "#166534"
      stroke-width: 2
      font-size: 36
    }
  }
  lc: {
    style: {
      fill: "#A9C7E6"
      stroke: "#5B65C9"
      stroke-width: 2
      border-radius: 20
      font-size: 40
    }
  }
  pc: {
    style: {
      fill: "#FFF8BF"
      stroke: "#D1B24A"
      stroke-width: 2
      font-size: 40
    }
  }
  sys: {
    style: {
      fill: "#E6E6E6"
      stroke: "#9A9A9A"
      stroke-width: 2
      font-size: 48
    }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"
      stroke: "#5B65C9"
      stroke-width: 2
      border-radius: 20
      font-size: 40
    }
  }
  note: {
    style: {
      fill: "#FFF5B0"
      stroke: "#D1B24A"
      font-size: 32
    }
  }
  chain: {
    style: {
      fill: "#FFFFFF"
      stroke: "#D1B24A"
      stroke-width: 2
      border-radius: 20
      font-size: 36
    }
  }
  fe: {
    style: {
      stroke: "#1F7A4D"
      font-color: "#1F7A4D"
      stroke-width: 2
      font-size: 30
    }
  }
  ce: {
    style: {
      stroke: "#5B65C9"
      font-color: "#5B65C9"
      stroke-width: 2
      font-size: 30
    }
  }
  pl: {
    style: {
      stroke: "#E11D28"
      font-color: "#E11D28"
      stroke-width: 2
      font-size: 30
    }
  }
  cstr: {
    style: {
      stroke: "#333333"
      stroke-dash: 3
      font-size: 26
    }
  }
}


direction: down

admin_device: "[EA] Employee Client Device" {
  class: ea
  shape: rectangle
  direction: down
  grid-columns: 1

  authenticate_as_admin: "[F] Authenticate as\nadministrator" {
    class: func
    shape: rectangle
  }
  provision_manage_accounts: "[F] Provision and manage\nuser accounts" {
    class: func
    shape: rectangle
  }
}

employee_device: "[EA] Employee Client Device" {
  class: ea
  shape: rectangle
  direction: down
  grid-columns: 1

  authenticate_dashboard_access: "[F] Authenticate to access\nthe dashboard" {
    class: func
    shape: rectangle
  }
}

platform: "[System] Aqueduct monitoring platform" {
  class: sys
  direction: down
  grid-columns: 1

  server_host: "[PC] DigitalOcean Premium AMD Droplet\n(4 vCPU / 8 GiB RAM / 160 GiB SSD)" {
    class: pc
    direction: right
    grid-columns: 4

    traefik_container: "[LC] Traefik Reverse Proxy Container" {
      class: lc
      direction: down
      grid-columns: 1

      gateway: "[LC] Reverse Proxy /\nTLS Gateway" {
        class: lc
        direction: down
        grid-columns: 1

        route_identity_request: "[F] Terminate TLS and\nroute identity request" {
          class: func
          shape: rectangle
        }
      }
    }

    grafana_container: "[LC] Grafana Dashboard Container" {
      class: lc
      direction: down
      grid-columns: 1

      dashboard_lc: "[LC] Dashboard" {
        class: lc
        direction: down
        grid-columns: 1

        authenticate_user: "[F] Authenticate\nuser" {
          class: func
          shape: rectangle
        }
      }
    }

    keycloak_container: "[LC] Keycloak Identity Container" {
      class: lc
      direction: right
      grid-columns: 2

      credential_policy_lc: "[LC] Credential Policy\nRBAC + MFA + lockout" {
        class: lc
        direction: down
        grid-columns: 1

        enforce_credential_policy: "[F] Enforce password policy,\nRBAC, MFA, and lockout" {
          class: func
          shape: rectangle
        }
      }

      account_provisioning_lc: "[LC] Account\nProvisioning" {
        class: lc
        direction: down
        grid-columns: 1

        manage_accounts: "[F] Create, update, and\ndisable user accounts" {
          class: func
          shape: rectangle
        }
      }

      credential_validation_lc: "[LC] Credential Validation\nand OIDC Token Issuance" {
        class: lc
        direction: down
        grid-columns: 1

        validate_credentials_issue_token: "[F] Validate credentials\nand issue identity token" {
          class: func
          shape: rectangle
        }
      }

      credential_store_lc: "[LC] Salted Password Hashing\nand Credential Storage" {
        class: lc
        direction: down
        grid-columns: 1

        hash_store_credentials: "[F] Salt, hash, and\nstore credentials" {
          class: func
          shape: rectangle
        }
      }
    }

    postgres_container: "[LC] PostgreSQL 16 Container" {
      class: lc
      direction: down
      grid-columns: 1

      identity_store_lc: "[LC] Identity Store" {
        class: lc
        direction: down
        grid-columns: 1

        store_identity_data: "[F] Store account data\nand salted hash" {
          class: func
          shape: rectangle
        }
        provide_stored_hash: "[F] Provide stored\ncredential hash" {
          class: func
          shape: rectangle
        }
      }
    }
  }

  storage_note: "[C] Passwords are not stored in Grafana or FastAPI.\nKeycloak stores only salted password hashes in PostgreSQL" {
    class: note
    shape: page
  }
  admin_note: "[C] Administrator access requires RBAC and MFA\nwith strong password policy" {
    class: note
    shape: page
  }
  builtin_note: "[C] Keycloak logical components shown here are\nproduct-provided capabilities" {
    class: note
    shape: page
  }
  transport_note: "[C] TLS is terminated at Traefik before routing\nto Grafana or Keycloak" {
    class: note
    shape: page
  }
}

admin_device -> employee_device: {
  style: { opacity: 0 }
}
employee_device -> platform: {
  style: { opacity: 0 }
}

admin_device.authenticate_as_admin -> platform.server_host.traefik_container.gateway.route_identity_request: "[FE] HTTPS admin\nlogin request" {
  class: fe
}
platform.server_host.traefik_container.gateway.route_identity_request -> platform.server_host.keycloak_container.credential_validation_lc.validate_credentials_issue_token: "[FE] Routed admin\nauthentication" {
  class: fe
}
platform.server_host.keycloak_container.credential_policy_lc.enforce_credential_policy -> platform.server_host.keycloak_container.credential_validation_lc.validate_credentials_issue_token: "[FE] Apply MFA\n+ lockout rules" {
  class: fe
}

admin_device.provision_manage_accounts -> platform.server_host.traefik_container.gateway.route_identity_request: "[FE] HTTPS account\nmanagement" {
  class: fe
}
platform.server_host.traefik_container.gateway.route_identity_request -> platform.server_host.keycloak_container.account_provisioning_lc.manage_accounts: "[FE] Routed account\nadministration" {
  class: fe
}
platform.server_host.keycloak_container.credential_policy_lc.enforce_credential_policy -> platform.server_host.keycloak_container.account_provisioning_lc.manage_accounts: "[FE] Apply password\npolicy + RBAC" {
  class: fe
}
platform.server_host.keycloak_container.account_provisioning_lc.manage_accounts -> platform.server_host.keycloak_container.credential_store_lc.hash_store_credentials: "[FE] Create / update\ncredential" {
  class: fe
}
platform.server_host.keycloak_container.credential_store_lc.hash_store_credentials -> platform.server_host.postgres_container.identity_store_lc.store_identity_data: "[FE] Store account data\n+ salted hash" {
  class: fe
}

employee_device.authenticate_dashboard_access -> platform.server_host.traefik_container.gateway.route_identity_request: "[FE] HTTPS employee\nlogin request" {
  class: fe
}
platform.server_host.traefik_container.gateway.route_identity_request -> platform.server_host.grafana_container.dashboard_lc.authenticate_user: "[FE] Routed dashboard\nrequest" {
  class: fe
}
platform.server_host.grafana_container.dashboard_lc.authenticate_user -> platform.server_host.keycloak_container.credential_validation_lc.validate_credentials_issue_token: "[FE] OIDC auth\nrequest" {
  class: fe
}
platform.server_host.keycloak_container.credential_validation_lc.validate_credentials_issue_token -> platform.server_host.postgres_container.identity_store_lc.provide_stored_hash: "[FE] Retrieve stored\ncredential hash" {
  class: fe
}
platform.server_host.postgres_container.identity_store_lc.provide_stored_hash -> platform.server_host.keycloak_container.credential_validation_lc.validate_credentials_issue_token: "[FE] Stored credential\nhash" {
  class: fe
}
platform.server_host.keycloak_container.credential_validation_lc.validate_credentials_issue_token -> platform.server_host.grafana_container.dashboard_lc.authenticate_user: "[FE] Identity token\n/ claims" {
  class: fe
}

platform.storage_note -> platform.server_host.keycloak_container.credential_store_lc {
  class: cstr
}
platform.admin_note -> platform.server_host.keycloak_container.credential_policy_lc {
  class: cstr
}
platform.builtin_note -> platform.server_host.keycloak_container {
  class: cstr
}
platform.transport_note -> platform.server_host.traefik_container.gateway {
  class: cstr
}
