vars: {
  d2-config: {
    layout-engine: elk
  }
}

classes: {
  func: {
    shape: rectangle
    style: {
      fill: "#BDFB9B"
      stroke: "#166534"
      stroke-width: 2
      font-size: 36
    }
  }
  lc: {
    style: {
      fill: "#A9C7E6"
      stroke: "#5B65C9"
      stroke-width: 2
      border-radius: 20
      font-size: 40
    }
  }
  pc: {
    style: {
      fill: "#FFF8BF"
      stroke: "#D1B24A"
      stroke-width: 2
      font-size: 40
    }
  }
  sys: {
    style: {
      fill: "#E6E6E6"
      stroke: "#9A9A9A"
      stroke-width: 2
      font-size: 48
    }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"
      stroke: "#5B65C9"
      stroke-width: 2
      border-radius: 20
      font-size: 40
    }
  }
  note: {
    style: {
      fill: "#FFF5B0"
      stroke: "#D1B24A"
      font-size: 32
    }
  }
  chain: {
    style: {
      fill: "#FFFFFF"
      stroke: "#D1B24A"
      stroke-width: 2
      border-radius: 20
      font-size: 36
    }
  }
  fe: {
    style: {
      stroke: "#1F7A4D"
      font-color: "#1F7A4D"
      stroke-width: 2
      font-size: 30
    }
  }
  ce: {
    style: {
      stroke: "#5B65C9"
      font-color: "#5B65C9"
      stroke-width: 2
      font-size: 30
    }
  }
  pl: {
    style: {
      stroke: "#E11D28"
      font-color: "#E11D28"
      stroke-width: 2
      font-size: 30
    }
  }
  cstr: {
    style: {
      stroke: "#333333"
      stroke-dash: 3
      font-size: 26
    }
  }
}

direction: right

bench_baseline: "[System] Functional Version 2 — Bench Field Node\nwith Real Controller and Dummy Sensors" {
  class: sys
  direction: right
  grid-columns: 2

  bench_field_node: "[PC] Bench Field Node" {
    class: pc
    direction: down
    grid-columns: 1

    bench_supply: "[PC] Bench DC Supply" {
      class: pc
    }
    flow_simulator: "[PC] Modbus RTU\nFlow Simulator" {
      class: pc
    }
    depth_emulator: "[PC] Analog Depth\nEmulator" {
      class: pc
    }

    controller_pcb: "[PC] Controller PCB" {
      class: pc
      direction: right
      grid-columns: 4

      power_subsystem: "[PC] Power Subsystem" {
        class: pc
        direction: down
        grid-columns: 1

        solar_manager: "[PC] Waveshare Solar Power Manager (D)\nMPPT Charger + 5 V Output" {
          class: pc
        }
        battery_pack: "[PC] 18650 Battery Holder\n+ 3P1S Li-ion Pack" {
          class: pc
        }
        battery_monitor: "[PC] INA219 Battery Monitor" {
          class: pc
        }
        power_header: "[PC] Molex MicroFit 43045\n4-pin Power Header" {
          class: pc
        }
      }

      compute_subsystem: "[PC] Compute" {
        class: pc
        direction: down
        grid-columns: 1

        expansion_board: "[PC] Seeed Studio Expansion Board Base for XIAO\n(includes RTC + MicroSD slot)" {
          class: pc
          direction: down
          grid-columns: 1

          xiao_module: "[PC] Seeed XIAO ESP32-C3" {
            class: pc
            direction: down
            grid-columns: 1

            data_acquisition: "[LC] Data Acquisition" {
              class: lc
            }
          }

          xiao_header: "[PC] GPIO / I²C / UART\nPin Header" {
            class: pc
          }
        }
      }

      sensor_interfaces: "[PC] Sensor Interfaces" {
        class: pc
        direction: down
        grid-columns: 1

        rs485_interface: "[PC] Seeed Grove\nRS485" {
          class: pc
        }
        analog_divider: "[PC] Analog\nDivider" {
          class: pc
        }
      }

      wan_interface: "[PC] WAN Interface" {
        class: pc
        direction: down
        grid-columns: 1

        lte_module: "[PC] Waveshare SIM7600G-H\n4G Module" {
          class: pc
        }
      }
    }

    cellular_antenna: "[PC] Waveshare 4G/3G/2G/LPWA\nOutdoor Antenna" {
      class: pc
    }

    bench_note: "[C] Bench DC input temporarily substitutes the final\nsolar panel while controller, battery, and charger\nbehavior are integrated" {
      class: note
      shape: page
    }
    flow_note: "[C] Modbus RTU simulator temporarily substitutes\nthe final flow source for interface and parser verification" {
      class: note
      shape: page
    }
    depth_note: "[C] Analog emulator temporarily substitutes the final\nlevel sensor for scaling and health-state verification" {
      class: note
      shape: page
    }
    exit_note: "[C] Exit when the real XIAO-based node reads both\nsubstitutes, reports power and modem health,\nand uploads successfully" {
      class: note
      shape: page
    }
  }

  ingress_subset: "[PC] Server Ingress Subset" {
    class: pc
    direction: right
    grid-columns: 3

    traefik_container: "[LC] Traefik Reverse Proxy Container" {
      class: lc
      direction: down
      grid-columns: 1

      gateway: "[LC] Reverse Proxy /\nTLS Gateway" {
        class: lc
      }
    }

    fastapi_container: "[LC] FastAPI Application Container" {
      class: lc
      direction: down
      grid-columns: 1

      node_ingestion: "[LC] Node Ingestion" {
        class: lc
      }
    }

    influxdb_container: "[LC] InfluxDB OSS 2.7 Container" {
      class: lc
      direction: down
      grid-columns: 1

      long_term_storage: "[LC] Long-term Storage" {
        class: lc
      }
    }
  }
}

bench_baseline.bench_field_node.controller_pcb.power_subsystem.battery_pack -> bench_baseline.bench_field_node.controller_pcb.power_subsystem.battery_monitor: {
  style: { opacity: 0 }
}
bench_baseline.bench_field_node.controller_pcb.power_subsystem.battery_monitor -> bench_baseline.bench_field_node.controller_pcb.power_subsystem.solar_manager: {
  style: { opacity: 0 }
}
bench_baseline.bench_field_node.controller_pcb.power_subsystem.solar_manager -> bench_baseline.bench_field_node.controller_pcb.power_subsystem.power_header: {
  style: { opacity: 0 }
}
bench_baseline.bench_field_node.flow_simulator -> bench_baseline.bench_field_node.depth_emulator: {
  style: { opacity: 0 }
}
bench_baseline.bench_field_node.controller_pcb.sensor_interfaces.rs485_interface -> bench_baseline.bench_field_node.controller_pcb.sensor_interfaces.analog_divider: {
  style: { opacity: 0 }
}

bench_baseline.bench_field_node.bench_supply <-> bench_baseline.bench_field_node.controller_pcb.power_subsystem.solar_manager: "[PL] DC input" {
  class: pl
}
bench_baseline.bench_field_node.controller_pcb.power_subsystem.battery_pack <-> bench_baseline.bench_field_node.controller_pcb.power_subsystem.solar_manager: "[PL] 2-wire JST" {
  class: pl
}
bench_baseline.bench_field_node.controller_pcb.power_subsystem.battery_pack <-> bench_baseline.bench_field_node.controller_pcb.power_subsystem.battery_monitor: "[PL] BAT+ / BAT−" {
  class: pl
}
bench_baseline.bench_field_node.controller_pcb.power_subsystem.solar_manager <-> bench_baseline.bench_field_node.controller_pcb.power_subsystem.power_header: "[PL] 5 V + GND" {
  class: pl
}
bench_baseline.bench_field_node.controller_pcb.power_subsystem.power_header <-> bench_baseline.bench_field_node.controller_pcb.compute_subsystem.expansion_board.xiao_header: "[PL] 5 V + GND" {
  class: pl
}
bench_baseline.bench_field_node.controller_pcb.power_subsystem.power_header <-> bench_baseline.bench_field_node.controller_pcb.wan_interface.lte_module: "[PL] 5 V + GND" {
  class: pl
}

bench_baseline.bench_field_node.controller_pcb.compute_subsystem.expansion_board.xiao_header <-> bench_baseline.bench_field_node.controller_pcb.power_subsystem.battery_monitor: "[PL] SDA/SCL + 3.3 V + GND" {
  class: pl
}
bench_baseline.bench_field_node.controller_pcb.compute_subsystem.expansion_board.xiao_header <-> bench_baseline.bench_field_node.controller_pcb.sensor_interfaces.rs485_interface: "[PL] TX/RX + 5 V + GND" {
  class: pl
}
bench_baseline.bench_field_node.controller_pcb.compute_subsystem.expansion_board.xiao_header <-> bench_baseline.bench_field_node.controller_pcb.sensor_interfaces.analog_divider: "[PL] A0 + GND" {
  class: pl
}
bench_baseline.bench_field_node.controller_pcb.compute_subsystem.expansion_board.xiao_header <-> bench_baseline.bench_field_node.controller_pcb.wan_interface.lte_module: "[PL] TX/RX + PWK + GND" {
  class: pl
}

bench_baseline.bench_field_node.flow_simulator <-> bench_baseline.bench_field_node.controller_pcb.sensor_interfaces.rs485_interface: "[PL] RS485 A/B + GND" {
  class: pl
}
bench_baseline.bench_field_node.depth_emulator <-> bench_baseline.bench_field_node.controller_pcb.sensor_interfaces.analog_divider: "[PL] VOUT + 5 V + GND" {
  class: pl
}
bench_baseline.bench_field_node.cellular_antenna <-> bench_baseline.bench_field_node.controller_pcb.wan_interface.lte_module: "[PL] RF coax" {
  class: pl
}

bench_baseline.bench_field_node.controller_pcb.compute_subsystem.expansion_board.xiao_module.data_acquisition -> bench_baseline.ingress_subset.traefik_container.gateway: "[CE] HTTPS telemetry upload\nover cellular or lab WAN" {
  class: ce
}
bench_baseline.ingress_subset.traefik_container.gateway -> bench_baseline.ingress_subset.fastapi_container.node_ingestion: "[CE] Routed ingest\nrequest" {
  class: ce
}
bench_baseline.ingress_subset.fastapi_container.node_ingestion -> bench_baseline.ingress_subset.influxdb_container.long_term_storage: "[CE] Validated batch +\nhealth status" {
  class: ce
}

bench_baseline.bench_field_node.bench_note -> bench_baseline.bench_field_node.bench_supply: {
  class: cstr
}
bench_baseline.bench_field_node.flow_note -> bench_baseline.bench_field_node.flow_simulator: {
  class: cstr
}
bench_baseline.bench_field_node.depth_note -> bench_baseline.bench_field_node.depth_emulator: {
  class: cstr
}
bench_baseline.bench_field_node.exit_note -> bench_baseline.bench_field_node.controller_pcb.compute_subsystem.expansion_board.xiao_module.data_acquisition: {
  class: cstr
}
bench_baseline.bench_field_node.exit_note -> bench_baseline.ingress_subset.fastapi_container.node_ingestion: {
  class: cstr
}
